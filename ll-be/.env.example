DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/postgres
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=your-super-secret-key-change-me

# SMTP Settings (FastMail example)
MAIL_USERNAME=your-fastmail-email@fastmail.com
MAIL_PASSWORD=your-fastmail-app-password
MAIL_FROM=your-fastmail-email@fastmail.com
MAIL_PORT=587
MAIL_SERVER=smtp.fastmail.com
MAIL_FROM_NAME=LessonLift
MAIL_STARTTLS=True
MAIL_SSL_TLS=False

# LLM
LLM_PROVIDER=openai  # openai, anthropic, google
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
LLM_MODEL=gpt-4o

# LangSmith Tracing
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=<your-api-key>
LANGSMITH_PROJECT="project name"
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Search
TAVILY_API_KEY=your_tavily_api_key_here

# CORS Settings
# Format: JSON array of strings
ALLOWED_ORIGINS='["http://localhost:3000", "http://localhost:5173"]'